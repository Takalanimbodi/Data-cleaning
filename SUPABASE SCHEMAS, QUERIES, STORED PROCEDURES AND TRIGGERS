VALUES ('API_SECRET', ' ');



CREATE TRIGGER run_clustering_trigger
AFTER INSERT ON clean_customer_model_a
FOR EACH STATEMENT
EXECUTE FUNCTION trigger_clustering_api();

CREATE TRIGGER run_clustering_trigger_b
AFTER INSERT ON clean_customer_model_b
FOR EACH STATEMENT
EXECUTE FUNCTION trigger_clustering_api();
